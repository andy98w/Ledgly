{
  "name": "ledgly",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "db:generate": "pnpm --filter @ledgly/api db:generate",
    "db:push": "pnpm --filter @ledgly/api db:push",
    "db:migrate": "pnpm --filter @ledgly/api db:migrate",
    "db:studio": "pnpm --filter @ledgly/api db:studio",
    "clean": "turbo run clean && rm -rf node_modules",
    "prepare": "husky"
  },
  "lint-staged": {
    "apps/api/src/**/*.ts": ["eslint --fix"],
    "apps/web/**/*.{ts,tsx}": ["eslint --fix"]
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.2.5",
    "turbo": "^2.0.0",
    "typescript": "^5.4.0"
  }
}
