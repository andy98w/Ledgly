# ── API (Railway) ─────────────────────────────────────────────

# Database (auto-set by Railway when you add PostgreSQL)
DATABASE_URL="postgresql://user:pass@host:5432/ledgly"

# Auth
JWT_SECRET="generate-a-random-64-char-string"
JWT_EXPIRES_IN="7d"
MAGIC_LINK_EXPIRES_IN="15m"

# Email (Resend)
RESEND_API_KEY="re_your_api_key"
EMAIL_FROM="Ledgly <noreply@yourdomain.com>"

# App URLs (update after deploying)
API_URL="http://localhost:3001"
WEB_URL="http://localhost:3000"

# Environment
NODE_ENV="production"
PORT=3001

# AI Agent (optional)
ANTHROPIC_API_KEY="sk-ant-xxxxx"

# Gmail Sync (optional)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI=""

# Redis (optional)
REDIS_URL=""

# ── Web (Vercel) ──────────────────────────────────────────────

NEXT_PUBLIC_API_URL="https://your-api.up.railway.app/api/v1"
NEXT_PUBLIC_APP_URL="https://your-app.vercel.app"

# Supabase (optional, for avatar storage)
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
